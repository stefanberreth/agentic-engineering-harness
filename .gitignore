.DS_Store
*.swp
*.swo
*~

# Local session state (not project config)
# Legacy single-marker + per-hostname markers (used when running multiple
# AEH orchestrator sessions in separate Docker containers that bind-mount
# the same harness directory — each container gets its own persona.<hostname>).
.claude/persona
.claude/persona.*

# Harness-level secrets (personal API keys shared across targets)
.env

# Transient screenshots for human-Claude communication
docs/screenshots/

# Historical planning docs containing target-specific details
# These are transformation planning artifacts from specific targets;
# they served their purpose (the templates they designed are in place)
# but contain real project names/paths/stacks that must not be public.
# Kept on disk for local reference; untracked from public repo.
docs/aeh-status-report.md
docs/aeh-layered-implementation-plan.md
docs/aeh-autonomous-loop-implementation-plan.md
docs/aeh-layered-persona-architecture.md
docs/AE/reviews/layered-architecture-review.md

# Leak-detector local blocklist (real identifiers; never committed).
# Only bin/.leakage-patterns.example (placeholders) is tracked.
bin/.leakage-patterns

# Review-intermediary artefacts kept local-only.
# Findings reports and planning notes are local working drafts -- durable outputs
# are the resulting code/template changes + CHANGELOG/commit messages, not the
# intermediate report. See CLAUDE.md "Review intermediaries" rule.
comments.md
docs/reviewer-orchestrator-upgrade-notes.md
BACKLOG.md
*.private.md
*.local.md

# Target project workspaces (private, tracked by nested repo in targets/)
# Everything under targets/ is owned by the private targets repo.
# Nothing in targets/ is tracked by the public harness repo.
targets/
